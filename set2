        {
          "name": "stdout",
          "output_type": "stream",
          "text": "Word Frequencies:\n{'the': 2, 'quick': 1, 'brown': 1, 'fox': 1, 'jumps': 1, 'over': 1, 'lazy': 1, 'dog': 1}\n"
        }
      ],
      "execution_count": 1
